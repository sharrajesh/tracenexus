# LangSmith configuration - comma-separated for multiple instances
LANGSMITH_API_KEYS="key1,key2,key3"
LANGSMITH_NAMES="prod,dev,test"
# This will create tools: langsmith_prod_get_trace, langsmith_dev_get_trace, langsmith_test_get_trace

# Langfuse configuration - comma-separated for multiple instances
# IMPORTANT: values are positional. Item N in each LANGFUSE_* list must match.
# Repeat host values when multiple projects use the same Langfuse host.
LANGFUSE_NAMES="dev,prod,staging,nightly,services"
LANGFUSE_PUBLIC_KEYS="pk_dev,pk_prod,pk_staging,pk_nightly,pk_services"
LANGFUSE_SECRET_KEYS="sk_dev,sk_prod,sk_staging,sk_nightly,sk_services"
LANGFUSE_HOSTS="https://cloud.langfuse.com,https://cloud.langfuse.com,https://cloud.langfuse.com,https://cloud.langfuse.com,https://cloud.langfuse.com"
# Dashes become underscores in tool names (example):
# langfuse_dev_get_trace, langfuse_services_get_trace
